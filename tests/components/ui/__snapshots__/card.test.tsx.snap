exports[`Card snapshots bare Card 1`] = `"<div data-slot="card" class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm"></div>"`;

exports[`Card snapshots Card with all sub-components 1`] = `"<div data-slot="card" class="bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm"><div data-slot="card-header" class="@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6"><div data-slot="card-title" class="leading-none font-semibold">Tournament Results</div><div data-slot="card-description" class="text-muted-foreground text-sm">Saturday Rapid Arena — Round 5</div><div data-slot="card-action" class="col-start-2 row-span-2 row-start-1 self-start justify-self-end">Action</div></div><div data-slot="card-content" class="px-6">Main content goes here.</div><div data-slot="card-footer" class="flex items-center px-6 [.border-t]:pt-6">Footer info</div></div>"`;

exports[`Card snapshots CardHeader snapshot 1`] = `"<div data-slot="card-header" class="@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6"><div data-slot="card-title" class="leading-none font-semibold">Title</div></div>"`;

